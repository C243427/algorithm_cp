#include <iostream>
#include <algorithm>
using namespace std;
struct A {
    int s, f;
};
bool cmp(A a, A b) {
    return a.f < b.f;
}
int main() {
    int n;
    cin >> n;
    A a[100];
    for(int i = 0; i < n; i++) {
        cin >> a[i].s >> a[i].f;
    }
    sort(a, a + n, cmp);
    cout << "Selected activities:\n";
    int last = a[0].f;
    cout << a[0].s << " " << a[0].f << endl;
    for(int i = 1; i < n; i++) {
        if(a[i].s >= last) {
            cout << a[i].s << " " << a[i].f << endl;
            last = a[i].f;
        }
    }
    return 0;
}
